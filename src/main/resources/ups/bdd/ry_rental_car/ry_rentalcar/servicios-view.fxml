<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ups.bdd.ry_rental_car.ry_rentalcar.controllers.ServiciosController"
            stylesheets="@styles.css">

    <HBox spacing="45"
          AnchorPane.topAnchor="55"
          AnchorPane.leftAnchor="65"
          AnchorPane.rightAnchor="65">

        <VBox spacing="20"
              prefWidth="430"
              prefHeight="475"
              styleClass="table-card">

            <HBox spacing="15">
                <TextField fx:id="txtBuscar"
                           promptText="Buscar Servicios"
                           prefWidth="310"
                           prefHeight="40"
                           styleClass="search-input"/>

                <Button text="Buscar"
                        prefWidth="80"
                        prefHeight="40"
                        styleClass="btn-dark"/>
            </HBox>

            <TableView fx:id="tblServicios"
                       prefWidth="400"
                       prefHeight="270">

                <columns>
                    <TableColumn fx:id="colNombre" text="Servicio" prefWidth="105"/>
                    <TableColumn fx:id="colDescripcion" text="Descripción" prefWidth="145"/>
                    <TableColumn fx:id="colPrecio" text="Precio" prefWidth="75"/>
                    <TableColumn fx:id="colEstado" text="Estado" prefWidth="75"/>
                </columns>

            </TableView>

        </VBox>

        <VBox spacing="10"
              prefWidth="430"
              prefHeight="475"
              styleClass="form-card">

            <Label text="Datos del Servicio"
                   styleClass="form-title"/>

            <Label text="Nombre del servicio:" styleClass="field-label"/>
            <TextField fx:id="txtNombre" prefHeight="36"/>

            <Label text="Descripción:" styleClass="field-label"/>
            <TextField fx:id="txtDescripcion" prefHeight="36"/>

            <Label text="Precio:" styleClass="field-label"/>
            <TextField fx:id="txtPrecio" prefWidth="180" prefHeight="36"/>

            <Label text="Estado:" styleClass="field-label"/>
            <ComboBox fx:id="cmbEstado" prefWidth="220" prefHeight="36"/>

            <Label fx:id="lblMensaje" styleClass="error-text"/>

            <HBox spacing="15" alignment="CENTER">
                <Button text="Guardar"
                        styleClass="btn-dark"
                        prefWidth="145"
                        onAction="#guardarServicio"/>

                <Button text="Actualizar"
                        styleClass="btn-dark"
                        prefWidth="145"
                        onAction="#actualizarServicio"/>
            </HBox>

            <HBox alignment="CENTER">
                <Button text="Desactivar"
                        styleClass="btn-danger"
                        prefWidth="170"
                        onAction="#desactivarServicio"/>
            </HBox>

        </VBox>

    </HBox>

</AnchorPane>