<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ups.bdd.ry_rental_car.ry_rentalcar.controllers.VehiculosController"
            stylesheets="@styles.css">

    <HBox spacing="45"
          AnchorPane.topAnchor="50"
          AnchorPane.leftAnchor="65"
          AnchorPane.rightAnchor="65">

        <!-- Tabla y buscador -->
        <VBox spacing="20"
              prefWidth="430"
              prefHeight="520"
              styleClass="table-card">

            <HBox spacing="15">
                <TextField fx:id="txtBuscar"
                           promptText="Buscar Vehículos"
                           prefWidth="310"
                           prefHeight="40"
                           styleClass="search-input"/>

                <Button text="🔎"
                        prefWidth="48"
                        prefHeight="40"
                        styleClass="btn-dark"/>
            </HBox>

            <TableView fx:id="tblVehiculos"
                       prefWidth="400"
                       prefHeight="270">

                <columns>
                    <TableColumn fx:id="colMarcaModelo" text="Marca/Modelo" prefWidth="125"/>
                    <TableColumn fx:id="colMatricula" text="Matrícula" prefWidth="85"/>
                    <TableColumn fx:id="colPrecioDia" text="Precio/día" prefWidth="95"/>
                    <TableColumn fx:id="colEstado" text="Estado" prefWidth="95"/>
                </columns>

            </TableView>

        </VBox>

        <!-- Formulario -->
        <VBox spacing="8"
              prefWidth="430"
              prefHeight="520"
              styleClass="form-card">

            <Label text="Datos del Vehículo"
                   styleClass="form-title"/>

            <Label text="Marca:" styleClass="field-label"/>
            <ComboBox fx:id="cmbMarca" prefWidth="260" prefHeight="32"/>

            <Label text="Modelo:" styleClass="field-label"/>
            <ComboBox fx:id="cmbModelo" prefWidth="260" prefHeight="32"/>

            <Label text="Tipo:" styleClass="field-label"/>
            <ComboBox fx:id="cmbTipo" prefWidth="260" prefHeight="32"/>

            <HBox spacing="45">
                <VBox spacing="5">
                    <Label text="Año:" styleClass="field-label"/>
                    <TextField fx:id="txtAnio" prefWidth="160" prefHeight="32"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Matrícula:" styleClass="field-label"/>
                    <TextField fx:id="txtMatricula" prefWidth="160" prefHeight="32"/>
                </VBox>
            </HBox>

            <Label text="Precio/día:" styleClass="field-label"/>
            <TextField fx:id="txtPrecioDia" prefWidth="160" prefHeight="32"/>

            <Label text="Estado:" styleClass="field-label"/>
            <ComboBox fx:id="cmbEstado" prefWidth="260" prefHeight="32"/>

            <Label fx:id="lblMensaje" styleClass="error-text"/>

            <HBox spacing="15" alignment="CENTER">
                <Button text="Guardar"
                        styleClass="btn-dark"
                        prefWidth="145"
                        onAction="#guardarVehiculo"/>

                <Button text="Actualizar"
                        styleClass="btn-dark"
                        prefWidth="145"
                        onAction="#actualizarVehiculo"/>
            </HBox>

            <HBox alignment="CENTER">
                <Button text="Desactivar"
                        styleClass="btn-danger"
                        prefWidth="170"
                        onAction="#desactivarVehiculo"/>
            </HBox>

        </VBox>

    </HBox>

</AnchorPane>