<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ups.bdd.ry_rental_car.ry_rentalcar.controllers.ContratosController"
            stylesheets="@styles.css">

    <HBox spacing="45"
          AnchorPane.topAnchor="45"
          AnchorPane.leftAnchor="65"
          AnchorPane.rightAnchor="65">

        <VBox spacing="20" prefWidth="470" prefHeight="545" styleClass="table-card">

            <HBox spacing="15">
                <TextField fx:id="txtBuscar"
                           promptText="Buscar Contratos"
                           prefWidth="330"
                           prefHeight="40"
                           styleClass="search-input"/>

                <Button text="Buscar"
                        prefWidth="80"
                        prefHeight="40"
                        styleClass="btn-dark"/>
            </HBox>

            <TableView fx:id="tblContratos" prefWidth="440" prefHeight="315">
                <columns>
                    <TableColumn fx:id="colNumero" text="Número" prefWidth="85"/>
                    <TableColumn fx:id="colCliente" text="Cliente" prefWidth="100"/>
                    <TableColumn fx:id="colVehiculo" text="Vehículo" prefWidth="115"/>
                    <TableColumn fx:id="colTotal" text="Total" prefWidth="70"/>
                    <TableColumn fx:id="colEstado" text="Estado" prefWidth="70"/>
                </columns>
            </TableView>

        </VBox>

        <VBox spacing="7" prefWidth="430" prefHeight="545" styleClass="form-card">

            <Label text="Datos del Contrato" styleClass="form-title"/>

            <Label text="Reserva autorizada:" styleClass="field-label"/>
            <ComboBox fx:id="cmbReserva" prefWidth="310" prefHeight="32"/>

            <Label text="Usuario:" styleClass="field-label"/>
            <ComboBox fx:id="cmbUsuario" prefWidth="220" prefHeight="32"/>

            <HBox spacing="25">
                <VBox spacing="5">
                    <Label text="Fecha inicio:" styleClass="field-label"/>
                    <TextField fx:id="txtFechaInicio" editable="false" prefWidth="155" prefHeight="32"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Fecha fin:" styleClass="field-label"/>
                    <TextField fx:id="txtFechaFin" editable="false" prefWidth="155" prefHeight="32"/>
                </VBox>
            </HBox>

            <HBox spacing="25">
                <VBox spacing="5">
                    <Label text="Precio diario:" styleClass="field-label"/>
                    <TextField fx:id="txtPrecioDiario" editable="false" prefWidth="155" prefHeight="32"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Subtotal:" styleClass="field-label"/>
                    <TextField fx:id="txtSubtotal" editable="false" prefWidth="155" prefHeight="32"/>
                </VBox>
            </HBox>

            <HBox spacing="25">
                <VBox spacing="5">
                    <Label text="IVA:" styleClass="field-label"/>
                    <TextField fx:id="txtIva" editable="false" prefWidth="155" prefHeight="32"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Total:" styleClass="field-label"/>
                    <TextField fx:id="txtTotal" editable="false" prefWidth="155" prefHeight="32"/>
                </VBox>
            </HBox>

            <Label fx:id="lblMensaje" styleClass="error-text"/>

            <HBox spacing="12" alignment="CENTER">
                <Button text="Generar" styleClass="btn-dark" prefWidth="120" onAction="#generarContrato"/>
                <Button text="Actualizar" styleClass="btn-dark" prefWidth="120" onAction="#actualizarContrato"/>
            </HBox>

            <HBox alignment="CENTER">
                <Button text="Anular Contrato"
                        styleClass="btn-danger"
                        prefWidth="180"
                        onAction="#anularContrato"/>
            </HBox>

        </VBox>

    </HBox>

</AnchorPane>