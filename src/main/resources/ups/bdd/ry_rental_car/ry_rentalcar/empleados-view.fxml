<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ups.bdd.ry_rental_car.ry_rentalcar.controllers.EmpleadosController"
            stylesheets="@styles.css">

    <HBox spacing="45"
          AnchorPane.topAnchor="45"
          AnchorPane.leftAnchor="65"
          AnchorPane.rightAnchor="65">

        <VBox spacing="20" prefWidth="470" prefHeight="545" styleClass="table-card">

            <HBox spacing="15">
                <TextField fx:id="txtBuscar"
                           promptText="Buscar Empleados"
                           prefWidth="330"
                           prefHeight="40"
                           styleClass="search-input"/>

                <Button text="Buscar"
                        prefWidth="80"
                        prefHeight="40"
                        styleClass="btn-dark"/>
            </HBox>

            <TableView fx:id="tblEmpleados" prefWidth="440" prefHeight="315">
                <columns>
                    <TableColumn fx:id="colIdentificacion" text="Cédula" prefWidth="85"/>
                    <TableColumn fx:id="colNombre" text="Nombre" prefWidth="110"/>
                    <TableColumn fx:id="colTelefono" text="Teléfono" prefWidth="85"/>
                    <TableColumn fx:id="colRol" text="Rol" prefWidth="85"/>
                    <TableColumn fx:id="colEstado" text="Estado" prefWidth="75"/>
                </columns>
            </TableView>

        </VBox>

        <VBox spacing="7" prefWidth="430" prefHeight="545" styleClass="form-card">

            <Label text="Datos del Empleado" styleClass="form-title"/>

            <HBox spacing="25">
                <VBox spacing="5">
                    <Label text="Identificación:" styleClass="field-label"/>
                    <TextField fx:id="txtIdentificacion" prefWidth="170" prefHeight="32"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Teléfono:" styleClass="field-label"/>
                    <TextField fx:id="txtTelefono" prefWidth="170" prefHeight="32"/>
                </VBox>
            </HBox>

            <Label text="Nombres:" styleClass="field-label"/>
            <TextField fx:id="txtNombres" prefHeight="32"/>

            <Label text="Apellidos:" styleClass="field-label"/>
            <TextField fx:id="txtApellidos" prefHeight="32"/>

            <Label text="Dirección:" styleClass="field-label"/>
            <TextField fx:id="txtDireccion" prefHeight="32"/>

            <Label text="Correo:" styleClass="field-label"/>
            <TextField fx:id="txtCorreo" prefHeight="32"/>

            <HBox spacing="25">
                <VBox spacing="5">
                    <Label text="Rol:" styleClass="field-label"/>
                    <ComboBox fx:id="cmbRol" prefWidth="170" prefHeight="32"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Estado:" styleClass="field-label"/>
                    <ComboBox fx:id="cmbEstado" prefWidth="170" prefHeight="32"/>
                </VBox>
            </HBox>

            <Label fx:id="lblMensaje" styleClass="error-text"/>

            <HBox spacing="15" alignment="CENTER">
                <Button text="Guardar"
                        styleClass="btn-dark"
                        prefWidth="130"
                        onAction="#guardarEmpleado"/>

                <Button text="Actualizar"
                        styleClass="btn-dark"
                        prefWidth="130"
                        onAction="#actualizarEmpleado"/>
            </HBox>

            <HBox alignment="CENTER">
                <Button text="Desactivar"
                        styleClass="btn-danger"
                        prefWidth="170"
                        onAction="#desactivarEmpleado"/>
            </HBox>

        </VBox>

    </HBox>

</AnchorPane>