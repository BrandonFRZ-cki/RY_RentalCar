<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ups.bdd.ry_rental_car.ry_rentalcar.controllers.ReservasController"
            stylesheets="@styles.css">

    <HBox spacing="45"
          AnchorPane.topAnchor="50"
          AnchorPane.leftAnchor="65"
          AnchorPane.rightAnchor="65">

        <VBox spacing="20" prefWidth="470" prefHeight="520" styleClass="table-card">

            <HBox spacing="15">
                <TextField fx:id="txtBuscar"
                           promptText="Buscar Reservas"
                           prefWidth="330"
                           prefHeight="40"
                           styleClass="search-input"/>

                <Button text="Buscar"
                        prefWidth="80"
                        prefHeight="40"
                        styleClass="btn-dark"/>
            </HBox>

            <TableView fx:id="tblReservas" prefWidth="440" prefHeight="300">
                <columns>
                    <TableColumn fx:id="colCliente" text="Cliente" prefWidth="100"/>
                    <TableColumn fx:id="colVehiculo" text="Vehículo" prefWidth="120"/>
                    <TableColumn fx:id="colFechaInicio" text="Inicio" prefWidth="75"/>
                    <TableColumn fx:id="colFechaFin" text="Fin" prefWidth="75"/>
                    <TableColumn fx:id="colEstado" text="Estado" prefWidth="80"/>
                </columns>
            </TableView>

        </VBox>

        <VBox spacing="8" prefWidth="430" prefHeight="520" styleClass="form-card">

            <Label text="Datos de la Reserva" styleClass="form-title"/>

            <Label text="Cliente:" styleClass="field-label"/>
            <ComboBox fx:id="cmbCliente" prefWidth="300" prefHeight="34"/>

            <Label text="Vehículo:" styleClass="field-label"/>
            <ComboBox fx:id="cmbVehiculo" prefWidth="300" prefHeight="34"/>

            <Label text="Usuario:" styleClass="field-label"/>
            <ComboBox fx:id="cmbUsuario" prefWidth="220" prefHeight="34"/>

            <HBox spacing="25">
                <VBox spacing="5">
                    <Label text="Fecha inicio:" styleClass="field-label"/>
                    <TextField fx:id="txtFechaInicio" promptText="2026-07-10" prefWidth="160" prefHeight="34"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Fecha fin:" styleClass="field-label"/>
                    <TextField fx:id="txtFechaFin" promptText="2026-07-12" prefWidth="160" prefHeight="34"/>
                </VBox>
            </HBox>

            <Label text="Estado:" styleClass="field-label"/>
            <ComboBox fx:id="cmbEstado" prefWidth="220" prefHeight="34"/>

            <Label fx:id="lblMensaje" styleClass="error-text"/>

            <HBox spacing="12" alignment="CENTER">
                <Button text="Guardar" styleClass="btn-dark" prefWidth="120" onAction="#guardarReserva"/>
                <Button text="Actualizar" styleClass="btn-dark" prefWidth="120" onAction="#actualizarReserva"/>
                <Button text="Autorizar" styleClass="btn-outline" prefWidth="120" onAction="#autorizarReserva"/>
            </HBox>

            <HBox alignment="CENTER">
                <Button text="Cancelar Reserva"
                        styleClass="btn-danger"
                        prefWidth="180"
                        onAction="#cancelarReserva"/>
            </HBox>

        </VBox>

    </HBox>

</AnchorPane>