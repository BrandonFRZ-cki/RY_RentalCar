<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ups.bdd.ry_rental_car.ry_rentalcar.controllers.MainController"
            stylesheets="@styles.css"
            prefWidth="1200"
            prefHeight="700">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="header-bar">
            <ImageView fitWidth="220" preserveRatio="true">
                <image>
                    <Image url="@img/logo.png"/>
                </image>
            </ImageView>

            <Label fx:id="lblUsuario" text="Admin:"/>
        </HBox>
    </top>

    <left>
        <VBox styleClass="sidebar" prefWidth="230" spacing="8">
            <padding>
                <Insets top="20" bottom="20"/>
            </padding>

            <Button text="Clientes" styleClass="nav-button" onAction="#mostrarClientes"/>
            <Button text="Vehículos" styleClass="nav-button" onAction="#mostrarVehiculos"/>
            <Button text="Servicios" styleClass="nav-button" onAction="#mostrarServicios"/>
            <Button text="Reservas" styleClass="nav-button" onAction="#mostrarReservas"/>
            <Button text="Contratos" styleClass="nav-button" onAction="#mostrarContratos"/>
            <Button text="Empleados" styleClass="nav-button" onAction="#mostrarEmpleados"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea"/>
    </center>

</BorderPane>